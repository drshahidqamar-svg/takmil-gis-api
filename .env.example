# TAKMIL GIS API — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.dzngihxzmbnwvypzavzl.supabase.co:5432/postgres

# JWT secret — use any long random string
JWT_SECRET=takmil-gis-super-secret-change-this-in-production

# Port (Railway sets this automatically)
PORT=3000

# School access threshold in miles
ACCESS_THRESHOLD_MILES=3.0

# Google Maps API key (for Places API)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
